# --- Firebase (client-safe; optional NEXT_PUBLIC_ prefix in some setups) ---
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# --- AgriBot chat (server-only) — OpenRouter ---
# Get a key at https://openrouter.ai/keys — add credits if you see HTTP 402 in server logs.
OPENROUTER_API_KEY=
# Optional: model id on OpenRouter (default: meta-llama/llama-3.3-70b-instruct:free)
# If the default returns 402, try another model you have access to, e.g.:
# OPENROUTER_MODEL=openai/gpt-oss-120b:free
# OPENROUTER_MODEL=
# Optional: site URL for OpenRouter rankings (default placeholder)
# OPENROUTER_SITE_URL=https://your-domain.com

# --- Disease detection API (FastAPI) — used on the client after build-time mapping ---
# Set ML_API_URL; next.config maps it to NEXT_PUBLIC_ML_API_URL for the detect page.
ML_API_URL=http://127.0.0.1:8000

# --- Sensor ingest (ESP32 → POST /sensor) — optional; when set, require Authorization: Bearer <secret> ---
# SENSOR_INGEST_SECRET=
